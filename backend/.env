# === Django (dev) ===
DJANGO_SECRET_KEY=dev-reset-key-please-change
APP_VERSION=dev
DEBUG=True

# Locale
LANGUAGE_CODE=pt-br
TIME_ZONE=America/Sao_Paulo

# Hosts/CORS (inclua seu IP local se quiser abrir o Vite no celular)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.129
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.0.129:5173
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=

# === Database (Docker Postgres mapeia host 55432 -> container 5432) ===
DB_ENGINE=django.db.backends.postgresql
DB_NAME=clinic_local
DB_USER=clinic
DB_PASSWORD=clinicpass
DB_HOST=127.0.0.1
DB_PORT=55432

# Safety toggles
ALLOW_REMOTE_DB_IN_DEBUG=False
ALLOW_OTP_FALLBACK=False
OTP_FALLBACK_CODE=

# === Email (dev) ===
# Em desenvolvimento, use o backend de console para evitar falhas de SMTP/acesso indevido
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=clinic@example.com

# Opcional: SMTP real (APENAS se quiser testar envio real em dev)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.mail.me.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Clinica <no-reply@exemplo.com>
